  int temp = displayTime;
  for(int i = 3; i >= 0; i--) {
    data[3-i] = customEncode(temp % 10);
    temp /= 10;
  }
  tm.setSegments(data);
  while(Serial.available()) {
    char c = Serial.read();
    if(c == '\n' || c == '\r') {
      if(input.length() > 0) {
        uint8_t data[4] = {0,0,0,0};
        for(int i = 0; i < 4 && i < input.length(); i++) {
          if(input[i] >= '0' && input[i] <= '9') {
            data[3-i] = customEncode(input[i] - '0');
            
          }
        }
        tm.setSegments(data);
        input = "";
      }
    } else input += c;
  }

  int adc = analogRead(34);
  roomtemp = 3 + (2020 - adc) * 0.06;
  
