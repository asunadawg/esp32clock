#define OLED_RESET    -1
#define SCREEN_ADDRESS 0x3C

#define CLK 25
#define DIO 26

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);
TM1637Display tm(CLK, DIO);

String input = "";

uint8_t customEncode(uint8_t n) {
  switch(n) {
    case 0: return 0b11100111;
    case 1: return 0b10000100;
    case 2: return 0b11010011;
    case 3: return 0b11010110;
    case 4: return 0b10110100;
    case 5: return 0b01110110;
    case 6: return 0b01110111;
    case 7: return 0b11000100;
    case 8: return 0b11110111;
    case 9: return 0b11110110;
  }
  return 0;
}

void setup() {
  Serial.begin(115200);
  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) for(;;);
  display.setRotation(2);
  tm.setBrightness(7);
}

void loop() {
