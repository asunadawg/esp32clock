    char c = Serial.read();
    if(c == '\n' || c == '\r') {
      if(input.length() > 0) {
        uint8_t data[4] = {0,0,0,0};
        for(int i = 0; i < 4 && i < input.length(); i++) {
          if(input[i] >= '0' && input[i] <= '9') {
            data[3-i] = customEncode(input[i] - '0');  // reversed
          }
        }
        tm.setSegments(data);
        input = "";
      }
