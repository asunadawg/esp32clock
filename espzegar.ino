void updateTime() {
  struct tm timeinfo;
  if (getLocalTime(&timeinfo)) {
    char buf[9];
    sprintf(buf, "%02d/%02d/%02d", timeinfo.tm_mday, timeinfo.tm_mon+1, timeinfo.tm_year % 100);
    dateStr = buf;
    displayTime = (timeinfo.tm_hour * 100) + timeinfo.tm_min;
  }
}

uint8_t customEncode(uint8_t displayTime) {
  switch(displayTime) {
    case 0: return 0b11100111;
    case 1: return 0b10000100;
    case 2: return 0b11010011;
    case 3: return 0b11010110;
    case 4: return 0b10110100;
    case 5: return 0b01110110;
    case 6: return 0b01110111;
    case 7: return 0b11000100;
    case 8: return 0b11110111;
    case 9: return 0b11110110;
  }
  return 0;
}

void setupWiFi() {
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    attempts++;
  }
}

void fetchWeather() {
  if (WiFi.status() != WL_CONNECTED) {
    outtemp = 00;
    return;
  }
  HTTPClient http;
  http.setConnectTimeout(5000);
  http.setTimeout(5000);
  if (!http.begin(weatherUrl)) return;
  int httpCode = http.GET();
  if (httpCode == 200) {
    String payload = http.getString();
    DynamicJsonDocument doc(2048);
    DeserializationError error = deserializeJson(doc, payload);
    if (!error) {
      outtemp = doc["main"]["temp"];
    } else {
      outtemp = 00;
    }
  } else {
    outtemp = -999;
  }
  http.end();
}

void setup() {
  Serial.begin(115200);
  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) for(;;);
  display.setRotation(2);
  tm.setBrightness(7);
  setupWiFi();
  configTime(0, 0, "pool.ntp.org");
  setenv("TZ", "CET-1CEST,M3.5.0,M10.5.0/3", 1);
  tzset();
}

void loop() {
  if (millis() - lastWeatherUpdate > weatherUpdateInterval) {
    fetchWeather();
    lastWeatherUpdate = millis();
  }

